; AltTaber Inno Setup Script
; Requires Inno Setup 6+

#define MyAppName "AltTaber"
#define MyAppVersion "@PROJECT_VERSION@"
#ifndef MyAppArch
  #define MyAppArch "win64"
#endif
#ifndef MyAppBuildDir
  #define MyAppBuildDir "..\build"
#endif
#define MyAppPublisher "MrBeanCpp"
#define MyAppURL "https://github.com/Hendrix4858/AltTaber"
#define MyAppExeName "AltTaber.exe"
#define MyAppId "AltTaber.MrBeanCpp"

[Setup]
AppId={#MyAppId}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
DefaultDirName={autopf}\{#MyAppName}
DefaultGroupName={#MyAppName}
OutputBaseFilename={#MyAppName}-v{#MyAppVersion}-{#MyAppArch}-Setup
OutputDir={#MyAppSourceDir}\build\output
SetupIconFile={#MyAppSourceDir}\img\icon.ico
UninstallDisplayIcon={app}\{#MyAppExeName}
PrivilegesRequired=admin
#if MyAppArch == "arm64"
  ArchitecturesInstallIn64BitMode=arm64
  ArchitecturesAllowed=arm64
#else
  ArchitecturesInstallIn64BitMode=x64os
  ArchitecturesAllowed=x64compatible
#endif
SolidCompression=yes
MinVersion=10.0.10240

[Languages]
Name: "en"; MessagesFile: "compiler:Default.isl"
Name: "zh"; MessagesFile: "{#MyAppSourceDir}\installer\ChineseSimplified.isl"

[CustomMessages]
en.AppRunningMsg=AltTaber is running. Please close it first.
zh.AppRunningMsg=AltTaber 正在运行，请先关闭它。
en.AppStillRunning=Still running. Click Retry after closing, or Cancel to abort.
zh.AppStillRunning=仍在运行。关闭后请点"重试"，或点"取消"中止。
en.GracefulCloseMsg=Close AltTaber automatically? (Recommended)
zh.GracefulCloseMsg=是否自动关闭 AltTaber？（推荐）
en.ForceKillMsg=Forcefully terminate AltTaber? (May cause data loss)
zh.ForceKillMsg=是否强制终止 AltTaber？（可能导致数据丢失）
en.KillFailedMsg=Failed to terminate AltTaber. Please close it manually.
zh.KillFailedMsg=无法终止 AltTaber。请手动关闭。
en.DeleteConfig=Delete configuration and settings?
zh.DeleteConfig=删除配置和设置？

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[Files]
Source: "{#MyAppBuildDir}\Release\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs restartreplace

[Icons]
Name: "{group}\{#MyAppName}"; Filename: "{app}\{#MyAppExeName}"
Name: "{group}\{cm:UninstallProgram,{#MyAppName}}"; Filename: "{uninstallexe}"
Name: "{commondesktop}\{#MyAppName}"; Filename: "{app}\{#MyAppExeName}"; Tasks: desktopicon

[Run]
Filename: "{app}\{#MyAppExeName}"; Description: "{cm:LaunchProgram,{#MyAppName}}"; Flags: nowait postinstall unchecked skipifsilent
Filename: "{app}\{#MyAppExeName}"; Flags: nowait skipifnotsilent

[UninstallDelete]
Type: filesandordirs; Name: "{app}\*"

[Code]
const
  WM_CLOSE = $0010;
  TH32CS_SNAPPROCESS = $00000002;
  INVALID_HANDLE_VALUE = -1;

type
  TProcessEntry32 = record
    dwSize: DWORD;
    cntUsage: DWORD;
    th32ProcessID: DWORD;
    th32DefaultHeapID: DWORD;
    th32ModuleID: DWORD;
    cntThreads: DWORD;
    th32ParentProcessID: DWORD;
    pcPriClassBase: Integer;
    dwFlags: DWORD;
    szExeFile: array[0..259] of Char;
  end;

function CreateToolhelp32Snapshot(dwFlags: DWORD; th32ProcessID: DWORD): Integer;
  external 'CreateToolhelp32Snapshot@kernel32.dll stdcall';
function Process32First(hSnapshot: Integer; var lppe: TProcessEntry32): Boolean;
  external 'Process32FirstW@kernel32.dll stdcall';
function Process32Next(hSnapshot: Integer; var lppe: TProcessEntry32): Boolean;
  external 'Process32NextW@kernel32.dll stdcall';
function CloseHandle(hObject: Integer): Boolean;
  external 'CloseHandle@kernel32.dll stdcall';
function PostMessage(hWnd: Integer; Msg: DWORD; wParam: DWORD; lParam: Integer): Boolean;
  external 'PostMessageW@user32.dll stdcall';
function GetTickCount: DWORD;
  external 'GetTickCount@kernel32.dll stdcall';

function CmdLineParamExists(const Param: string): Boolean;
var
  i: Integer;
begin
  Result := False;
  for i := 1 to ParamCount do
    if CompareText(ParamStr(i), Param) = 0 then
    begin
      Result := True;
      Exit;
    end;
end;

function IsAppRunning: Boolean;
var
  hSnap: Integer;
  pe: TProcessEntry32;
  exeFile: String;
  i: Integer;
begin
  Result := False;
  hSnap := CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
  if hSnap = INVALID_HANDLE_VALUE then
    Exit;
  pe.dwSize := SizeOf(pe);
  if Process32First(hSnap, pe) then begin
    repeat
      exeFile := '';
      for i := 0 to 259 do begin
        if pe.szExeFile[i] = #0 then Break;
        exeFile := exeFile + pe.szExeFile[i];
      end;
      if CompareText(exeFile, 'AltTaber.exe') = 0 then begin
        Result := True;
        Break;
      end;
    until not Process32Next(hSnap, pe);
  end;
  CloseHandle(hSnap);
end;

function WaitForAppExit(TimeoutMs: Integer): Boolean;
var
  Start: DWORD;
begin
  Start := GetTickCount;
  while IsAppRunning do begin
    Sleep(200);
    if (GetTickCount - Start) > TimeoutMs then begin
      Result := False;
      Exit;
    end;
  end;
  Result := True;
end;

// GracefulStopApp uses a layered approach:
//   1) Post WM_CLOSE to trigger Qt aboutToQuit + destructors
//   2) If still running: taskkill without /f (allows cleanup)
//   3) Returns False if app is still alive after both attempts
function GracefulStopApp: Boolean;
var
  hWnd: Integer;
  ResultCode: Integer;
begin
  // Step 1: Send WM_CLOSE — triggers Qt event loop to quit gracefully
  hWnd := FindWindowByWindowName('AltTaber');
  if hWnd <> 0 then begin
    PostMessage(hWnd, WM_CLOSE, 0, 0);
    if WaitForAppExit(4000) then begin
      Result := True;
      Exit;
    end;
  end;

  // Step 2: taskkill without /f — allows process to clean up resources
  if Exec(ExpandConstant('{sys}\taskkill.exe'), '/IM AltTaber.exe', '',
          SW_HIDE, ewWaitUntilTerminated, ResultCode) and (ResultCode = 0) then begin
    if WaitForAppExit(3000) then begin
      Result := True;
      Exit;
    end;
  end;

  Result := False;
end;

// ForceKillApp last resort: taskkill /f — only used when graceful close fails
function ForceKillApp: Boolean;
var
  ResultCode: Integer;
begin
  Result := Exec(ExpandConstant('{sys}\taskkill.exe'), '/F /IM AltTaber.exe', '',
                 SW_HIDE, ewWaitUntilTerminated, ResultCode) and (ResultCode = 0);
  if Result then
    WaitForAppExit(3000);
end;

// Escalating prompt loop:
//   Retry  — user says they closed it, re-check
//   Cancel → offer automatic close → GracefulStopApp
//         → if that fails, offer force kill → ForceKillApp
function PromptAndKillLoop: Boolean;
begin
  Result := False;
  while IsAppRunning do begin
    case MsgBox(CustomMessage('AppRunningMsg') + #13#10 + CustomMessage('AppStillRunning'),
                mbConfirmation, MB_RETRYCANCEL) of
      IDRETRY:
        begin
          // User closed it manually; re-check
        end;
      IDCANCEL:
        begin
          // Level 1: Suggest automatic graceful close
          if MsgBox(CustomMessage('GracefulCloseMsg'), mbConfirmation, MB_YESNO) = IDYES then begin
            if GracefulStopApp then begin
              Result := True;
              Exit;
            end;
            // Level 2: Graceful close failed — offer force kill as last resort
            if MsgBox(CustomMessage('ForceKillMsg'), mbConfirmation, MB_YESNO) = IDYES then begin
              if ForceKillApp then begin
                Result := True;
                Exit;
              end else begin
                MsgBox(CustomMessage('KillFailedMsg'), mbError, MB_OK);
              end;
            end;
          end;
          Exit;
        end;
    end;
  end;
  Result := True;
end;

function PrepareToInstall(var NeedsRestart: Boolean): String;
begin
  Result := '';
  if not IsAppRunning then
    Exit;
  if not PromptAndKillLoop then
    Result := 'Setup was cancelled by the user.';
end;

procedure BackupAndWriteMarker;
var
  MarkerPath, BackupDir: String;
  FindRec: TFindRec;
begin
  if DirExists(ExpandConstant('{app}')) then begin
    BackupDir := ExpandConstant('{userappdata}\MrBeanCpp\AltTaber\backup\{#MyAppVersion}');
    if not DirExists(BackupDir) then
      ForceDirectories(BackupDir);

    if FindFirst(ExpandConstant('{app}\*.exe'), FindRec) then begin
      try
        repeat
          FileCopy(ExpandConstant('{app}\') + FindRec.Name,
                   BackupDir + '\' + FindRec.Name, False);
        until not FindNext(FindRec);
      finally
        FindClose(FindRec);
      end;
    end;

    if FindFirst(ExpandConstant('{app}\*.dll'), FindRec) then begin
      try
        repeat
          FileCopy(ExpandConstant('{app}\') + FindRec.Name,
                   BackupDir + '\' + FindRec.Name, False);
        until not FindNext(FindRec);
      finally
        FindClose(FindRec);
      end;
    end;
  end;

  MarkerPath := ExpandConstant('{userappdata}\MrBeanCpp\AltTaber\update_marker.txt');
  ForceDirectories(ExpandConstant('{userappdata}\MrBeanCpp\AltTaber'));
  SaveStringToFile(MarkerPath, 'pending', False);
end;

procedure CurStepChanged(CurStep: TSetupStep);
var
  ResultCode: Integer;
begin
  if CurStep = ssInstall then
    BackupAndWriteMarker;
  if CurStep = ssDone then
    if CmdLineParamExists('/AUTOUPDATE') then
      Exec('cmd.exe', '/c (timeout /t 3 /nobreak > nul) & del /f /q "' + ExpandConstant('{srcexe}') + '"',
        '', SW_HIDE, ewNoWait, ResultCode);
end;

function InitializeUninstall: Boolean;
begin
  Result := True;
  if not IsAppRunning then
    Exit;
  if not PromptAndKillLoop then
    Result := False;

end;

procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);
var
  ConfigPath: String;
begin
  if CurUninstallStep = usPostUninstall then begin
    ConfigPath := ExpandConstant('{userappdata}\MrBeanCpp\AltTaber');
    if DirExists(ConfigPath) then begin
      if MsgBox(CustomMessage('DeleteConfig'), mbConfirmation, MB_YESNO) = IDYES then
        DelTree(ConfigPath, True, True, True);
    end;
  end;
end;
